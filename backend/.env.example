# Copy this file to .env and fill in real values. .env is gitignored -
# never commit real secrets.

# Required - Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional - defaults shown are used if unset
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True

# Required for AI Provider Mode's BYOK credential storage (Settings > AI
# Configuration > API Integrations) - encrypts customer API keys at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AI_CREDENTIAL_ENCRYPTION_KEY=

# Required for lawyer-invite / password-reset emails (any SMTP provider)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# URL of the running frontend - used to build links in emails
FRONTEND_URL=http://localhost:3000

# Optional - only needed for the Google Drive sync feature
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/google-drive/callback/
